# ============================================================
# VisionGuard AI — Environment Configuration
# Copy this to .env and fill in your values
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_NAME=VisionGuard AI
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=change-this-to-a-random-secret-key

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://visionguard:visionguard_pass@db:5432/visionguard

# ── YOLOv8 Detection ─────────────────────────────────────────
# Model sizes: yolov8n (fastest) → yolov8s → yolov8m → yolov8l → yolov8x (most accurate)
YOLO_MODEL=yolov8n.pt
CONFIDENCE_THRESHOLD=0.50
IOU_THRESHOLD=0.45
DEVICE=cpu
# DEVICE=cuda   # uncomment if you have an NVIDIA GPU

# ── LLM Configuration ────────────────────────────────────────
# Choose provider: huggingface OR openai
LLM_PROVIDER=huggingface

# HuggingFace (free, runs locally)
HUGGINGFACE_TOKEN=hf_your_token_here
LLM_MODEL=Qwen/Qwen2.5-1.5B-Instruct

# OpenAI (faster, requires API key + billing)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-3.5-turbo

# ── Risk Assessment ──────────────────────────────────────────
CROWD_THRESHOLD=5          # number of people to trigger crowd alert
HIGH_RISK_THRESHOLD=0.70

# ── Video Processing ─────────────────────────────────────────
MAX_VIDEO_FRAMES=300       # cap on frames to analyze per video
VIDEO_FRAME_SKIP=5         # analyze every Nth frame

# ── File Storage ─────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
RESULTS_DIR=/app/results
MAX_FILE_SIZE_MB=100

# ── Streamlit ────────────────────────────────────────────────
BACKEND_URL=http://backend:8000
